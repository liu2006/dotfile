BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
IndentAccessModifiers: false
AccessModifierOffset:  -4 
ColumnLimit: 80

BreakBeforeBraces: Custom
BraceWrapping:
  AfterFunction: true
  AfterClass: true
  AfterStruct: true
  AfterEnum: true

  AfterControlStatement: false
  BeforeElse: false
  BeforeCatch: false
